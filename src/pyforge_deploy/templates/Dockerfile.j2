FROM python:{{ python_image }} AS base
WORKDIR /app
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential gcc git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

FROM base AS builder
WORKDIR /app

COPY requirements-docker.txt ./
{% if report.heavy_hitters %}
COPY heavy-requirements.txt ./
{% endif %}

{% if use_wheelhouse %}
COPY wheels /wheels
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    python -m pip install --upgrade pip setuptools wheel
{% if report.heavy_hitters %}
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    python -m pip install --user --no-index --find-links /wheels -r heavy-requirements.txt
{% endif %}
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    python -m pip install --user --no-index --find-links /wheels -r requirements-docker.txt
{% else %}
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    python -m pip install --upgrade pip setuptools wheel
{% if report.heavy_hitters %}
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    python -m pip wheel --no-cache-dir -r heavy-requirements.txt -w /tmp/wheels && \
    python -m pip install --user --no-index --find-links /tmp/wheels -r heavy-requirements.txt
{% endif %}
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    python -m pip install --user --no-cache-dir -r requirements-docker.txt
{% endif %}

{% if report.has_pyproject %}
COPY . .
{% if use_wheelhouse %}
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    python -m pip install --user --no-index --find-links /wheels -r requirements-docker.txt && \
    python -m pip install --user --no-build-isolation --no-index --find-links /wheels .
{% else %}
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    python -m pip install --user --no-cache-dir -r requirements-docker.txt && \
    python -m pip install --user --no-build-isolation --no-cache-dir .
{% endif %}
{% endif %}

FROM python:{{ python_image }} AS runtime

WORKDIR /app
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

{% if non_root %}
RUN groupadd -r appuser && useradd -r -g appuser -d /home/appuser -m -s /bin/bash appuser
COPY --from=builder --chown=appuser:appuser /root/.local /home/appuser/.local
ENV PATH="/home/appuser/.local/bin:$PATH"
{% else %}
COPY --from=builder /root/.local /root/.local
ENV PATH="/root/.local/bin:$PATH"
{% endif %}

# Safety sync: ensure runtime dependencies exist in final image even if
# a previous layer cache or user-site copy misses transitive packages.
COPY --from=builder /app/requirements-docker.txt /tmp/requirements-docker.txt
{% if use_wheelhouse %}
COPY --from=builder /wheels /wheels
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    python -m pip install --no-cache-dir --no-index --find-links /wheels -r /tmp/requirements-docker.txt && \
    rm -rf /wheels /tmp/requirements-docker.txt
{% else %}
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    python -m pip install --no-cache-dir -r /tmp/requirements-docker.txt && \
    rm -f /tmp/requirements-docker.txt
{% endif %}

COPY --chown={% if non_root %}appuser:appuser{% else %}root:root{% endif %} . .

RUN find /app -type d -name '__pycache__' -prune -exec rm -rf {} + && \
    find /app -type f \( -name '*.pyc' -o -name '*.pyo' \) -delete && \
    rm -rf /app/build /app/dist /app/*.egg-info /app/tests /app/.git /app/.pytest_cache /app/.mypy_cache || true

{% if non_root %}
USER appuser
RUN rm -rf /home/appuser/.cache || true
{% else %}
RUN rm -rf /root/.cache || true
{% endif %}

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD python -c "import sys; sys.exit(0)" || exit 1

{% if entry_point %}
CMD ["python", "{{ entry_point }}"]
{% else %}
CMD ["python"]
{% endif %}
