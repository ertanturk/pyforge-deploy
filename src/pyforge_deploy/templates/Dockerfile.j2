FROM python:{{ python_version }}-slim

WORKDIR /app


RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*


{% if report.requirement_files %}
{% for file in report.requirement_files %}
COPY {{ file }} ./
{% endfor %}
RUN pip install --no-cache-dir --upgrade pip && \
    {% for file in report.requirement_files %}pip install --no-cache-dir -r {{ file }} && {% endfor %} true
{% endif %}


{% if not report.requirement_files and report.final_list %}
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir {{ report.final_list | join(' ') }}
{% endif %}


COPY . .

{% if report.has_pyproject %}
RUN pip install --no-cache-dir .
{% endif %}

ENV PYTHONUNBUFFERED=1

{% if entry_point %}
CMD ["python", "{{ entry_point }}"]
{% else %}
CMD ["python"]
{% endif %}